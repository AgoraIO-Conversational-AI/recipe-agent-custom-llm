# Agora credentials (required)
AGORA_APP_ID=your_agora_app_id
AGORA_APP_CERTIFICATE=your_agora_app_certificate

# Custom LLM endpoint (required)
# 1. Run: ngrok http 8001
# 2. Paste the ngrok URL here with /chat/completions at the end
CUSTOM_LLM_URL=https://YOUR-NGROK-URL.ngrok-free.app/chat/completions

# Optional — defaults work for the mock server
CUSTOM_LLM_API_KEY=any-key-here
CUSTOM_LLM_MODEL=mock-model
CUSTOM_LLM_PORT=8001
PORT=8000
