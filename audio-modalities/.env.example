# Agora credentials (required)
AGORA_APP_ID=your_agora_app_id
AGORA_APP_CERTIFICATE=your_agora_app_certificate

# Audio Modalities LLM endpoint (required)
# 1. Run: ngrok http 8001
# 2. Paste the ngrok URL here with /audio/chat/completions at the end
AUDIO_LLM_URL=https://YOUR-NGROK-URL.ngrok-free.app/audio/chat/completions

# Optional
AUDIO_LLM_API_KEY=any-key-here
AUDIO_LLM_MODEL=audio-mock
AUDIO_LLM_PORT=8001
PORT=8000
